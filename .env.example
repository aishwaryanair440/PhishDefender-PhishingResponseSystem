# PhishDefender Environment Variables
# Copy this file to .env and fill in your actual keys.
# Never commit the .env file.

# Get a free key at https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# Get a free key at https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# Flask settings (optional, defaults shown)
FLASK_ENV=development
FLASK_HOST=127.0.0.1
FLASK_PORT=5000